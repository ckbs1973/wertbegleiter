# Copy to .env for local configuration. Never commit real secrets.
TRADING_SYSTEM_MODE=decision_support
LIVE_TRADING_ENABLED=false
DEFAULT_TIMEZONE=Europe/Berlin
DEFAULT_RISK_PERCENT=1.0

# Sekundenaktuelle Daten: echte Werte nur lokal in .env speichern.
# Ohne diese Verbindungen zeigt das Portal bewusst "Nicht live".
LIVE_FEED_ENABLED=false
LIVE_PRICE_STALE_AFTER_SECONDS=5
LIVE_ORDER_STALE_AFTER_SECONDS=5
LIVE_NEWS_STALE_AFTER_SECONDS=60
LIVE_CALENDAR_STALE_AFTER_SECONDS=900
CHAT_UPDATE_SERVICE_INTERVAL_SECONDS=5
CHAT_UPDATE_SERVICE_STALE_AFTER_SECONDS=15
LIVE_BRIDGE_INBOX=reports/live_bridge_inbox
LIVE_BRIDGE_INBOX_INTERVAL_SECONDS=1
LIVE_ADAPTER_TIMEOUT_SECONDS=5
LIVE_PRICE_JSON_PATH=
LIVE_ORDER_JSON_PATH=
LIVE_CALENDAR_JSON_PATH=
# JSON, RSS oder Atom. Beispiel nur als Platzhalter; echte Provider-URL lokal in .env setzen.
# LIVE_NEWS_FEED_URL=https://provider.example/feed.xml
LIVE_NEWS_FEED_URL=

# Lokale Starterpfade, falls noch kein echter Provider angebunden ist:
# LIVE_PRICE_JSON_PATH=reports/live_sources/tradingview_price.json
# LIVE_ORDER_JSON_PATH=reports/live_sources/tradingview_orders.json
# LIVE_CALENDAR_JSON_PATH=reports/live_sources/economic_calendar.json
# LIVE_NEWS_FEED_URL=reports/live_sources/news_squawk_xpro.json
TRADINGVIEW_WEBHOOK_LOCAL_PRICE_URL=http://127.0.0.1:8000/api/live-bridge/ingest
TRADINGVIEW_WEBHOOK_LOCAL_TRADE_URL=http://127.0.0.1:8000/api/trade-events/capture
# TradingView selbst braucht spaeter eine HTTPS-URL auf Port 443, z. B. Tunnel/Reverse Proxy.
TRADINGVIEW_WEBHOOK_PUBLIC_PRICE_URL=
TRADINGVIEW_WEBHOOK_PUBLIC_TRADE_URL=
TRADINGVIEW_GATEWAY_HOST=127.0.0.1
TRADINGVIEW_GATEWAY_PORT=8787
TRADINGVIEW_WEBHOOK_TOKEN=

TRADINGVIEW_BRIDGE_URL=
BROKER_EVENT_STREAM_URL=

# Option ohne Cloudflare: ALL-INKL/KAS Webhook Bridge.
# Deploy: deploy/kas_webhook_bridge auf den Webspace kopieren, config.php mit
# Token anlegen und diese URLs lokal in .env setzen.
# TRADINGVIEW_WEBHOOK_PUBLIC_PRICE_URL=https://wertbegleiter.eu/wb-bridge/tv/<token>/price
# TRADINGVIEW_WEBHOOK_PUBLIC_TRADE_URL=https://wertbegleiter.eu/wb-bridge/tv/<token>/trade
KAS_WEBHOOK_BRIDGE_EVENTS_URL=
KAS_WEBHOOK_BRIDGE_CURSOR_PATH=reports/live_sources/kas_webhook_bridge_cursor.json
KAS_WEBHOOK_BRIDGE_POLL_INTERVAL_SECONDS=3

ECONOMIC_CALENDAR_API_URL=
# Oeffentlicher News-Fallback, wenn kein Newsquawk/X-Pro-Feed vorhanden ist.
# FOREXLIVE_RSS_URL=https://investinglive.com/feed/
FOREXLIVE_RSS_URL=
NEWSQUAWK_API_URL=
X_PRO_LIST_URL=
SEEKING_ALPHA_NEWS_URL=

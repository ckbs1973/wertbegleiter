name = "wertbegleiter-trading-bridge"
main = "src/index.js"
compatibility_date = "2026-07-01"
workers_dev = true
preview_urls = false

# Nach `npx wrangler kv namespace create wertbegleiter_trading_events`
# die ausgegebene id hier eintragen und diese Datei als wrangler.toml kopieren.
[[kv_namespaces]]
binding = "EVENTS"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
